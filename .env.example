# Basis-URL deiner Supabase-Instanz (ohne abschließenden Slash)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Öffentlicher Supabase-Anon-Key (kein Service-Role-Key!)
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Optional für AI-Backend (ai/server.py, ai/train.py)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_SIDE_SERVICE_ROLE_KEY

# Optional: Standard-Vereins-ID für neue Installationen
VITE_DEFAULT_CLUB_ID=00000000-0000-0000-0000-000000000000

# Optional: eigene Superadmin-App (z. B. https://owner.asv-rotauge.de oder /superadmin.html)
VITE_SUPERADMIN_URL=/superadmin.html

# Optional: OneSignal App-ID (falls nicht gesetzt, wird ein Fallback aus dem Code genutzt)
VITE_ONESIGNAL_APP_ID=YOUR_ONESIGNAL_APP_ID

# Optional: AI-Endpunkt (fällt sonst auf https://ai.asv-rotauge.de zurück)
VITE_AI_BASE_URL=https://ai.asv-rotauge.de

# Optional: Frontend -> Ops Alerts (Supabase Edge Function opsAlert)
VITE_ENABLE_OPS_ALERTS=1

# Optional: Forecast-Retry (Frontend)
# Anzahl zusätzlicher Versuche bei transienten Fehlern (0-3)
VITE_FORECAST_RETRY_ATTEMPTS=1
# Wartezeit zwischen Versuchen in Millisekunden (0-5000)
VITE_FORECAST_RETRY_DELAY_MS=450

# Optional: zentraler Ops-Alert-Kanal (für Edge Functions + AI)
# Standardziel kann aus SUPABASE_URL auf /functions/v1/opsAlert abgeleitet werden.
OPS_ALERT_URL=
# Shared secret für trusted system callers (Edge/AI -> opsAlert)
OPS_ALERT_SECRET=
# Optional: zusätzlicher Webhook-Kanal (z. B. Slack Incoming Webhook)
OPS_ALERT_WEBHOOK_URL=
# Optional: Schwellwert für Benachrichtigungen: info|warning|error|critical
OPS_ALERT_MIN_SEVERITY=error
# Optional: Link im Alert (OneSignal/Webhook)
OPS_ALERT_WEB_URL=https://app.asv-rotauge.de
# Optional: Request-Timeout (Sekunden) für AI -> opsAlert Dispatch
OPS_ALERT_TIMEOUT_SECONDS=2.5

# Optional: Build-Metadaten (werden sonst automatisch generiert)
VITE_APP_VERSION=
VITE_BUILD_DATE=
VITE_GIT_COMMIT=
