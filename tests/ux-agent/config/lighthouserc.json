{
  "ci": {
    "collect": {
      "startServerCommand": "npm run build && npm run preview -- --host 127.0.0.1 --port 4173",
      "startServerReadyPattern": "Local",
      "url": [
        "http://127.0.0.1:4173/reset-done",
        "http://127.0.0.1:4173/asv-rotauge/auth"
      ],
      "numberOfRuns": 1,
      "settings": {
        "chromeFlags": "--headless=new --no-sandbox"
      }
    },
    "assert": {
      "assertions": {
        "categories:accessibility": [
          "error",
          {
            "minScore": 0.85
          }
        ],
        "categories:best-practices": [
          "error",
          {
            "minScore": 0.75
          }
        ],
        "categories:performance": [
          "warn",
          {
            "minScore": 0.4
          }
        ],
        "categories:seo": [
          "warn",
          {
            "minScore": 0.5
          }
        ],
        "categories:pwa": "off"
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": "tests/ux-agent/artifacts/lighthouse"
    }
  }
}
